# ============================================================
#  Competition Repository — .gitignore
# ============================================================

# --- OS Generated Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Build Artifacts ---
*.exe
*.out
*.o
*.obj
*.ilk
*.pdb
compiled/
com_log/
cmake-Build-debug/

# --- Logs ---
*.log

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/

# --- Node.js (future website) ---
node_modules/
dist/
.next/
.nuxt/
.output/

# --- Environment ---
.env
.env.local
.env.*.local

# --- Claude Code ---
.claude/

# --- Misc ---
*.tmp
*.temp
